<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quora Posts</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="page">

    <h1 class="title">Quora Posts</h1>

    <a href="/posts/new" class="create-btn">+ Create Post</a>

    <div class="posts">

        <% posts.forEach(post => { %>

            <div class="card">

                <div class="card-header">
                    <div class="avatar">
                        <%= post.username.charAt(0).toUpperCase() %>
                    </div>

                    <h3>@<%= post.username %></h3>
                </div>

                <p class="content">
                    <%= post.content.substring(0, 120) %>...
                </p>

                <a href="/posts/<%= post.id %>" class="view-btn">
                    View Post →
                </a>

                <a href="/posts/<%= post.id %>/edit" class="edit-btn">
                    Edit
                </a>

                <form method="POST" action="/posts/<%= post.id %>?_method=DELETE">
                    <button type="submit" class="delete-btn">
                        Delete
                    </button>
                </form>

            </div>

        <% }) %>

    </div>

</div>

</body>
</html>